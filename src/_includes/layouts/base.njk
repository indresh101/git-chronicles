<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {% if lang == "fr" %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}</title>
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
  {% if extra_css %}<link rel="stylesheet" href="{{ extra_css }}" media="print">{% endif %}
  {% if quest_id %}
  <link rel="alternate" hreflang="fr" href="/fr/quetes/{{ quest_slug_fr }}/">
  <link rel="alternate" hreflang="en" href="/en/quests/{{ quest_slug_en }}/">
  {% elif cheatsheet_slug_fr %}
  <link rel="alternate" hreflang="fr" href="/fr/cheatsheets/{{ cheatsheet_slug_fr }}/">
  <link rel="alternate" hreflang="en" href="/en/cheatsheets/{{ cheatsheet_slug_en }}/">
  {% else %}
  <link rel="alternate" hreflang="fr" href="/fr/">
  <link rel="alternate" hreflang="en" href="/en/">
  {% endif %}
  <link rel="alternate" hreflang="x-default" href="/fr/">
  <link rel="prefetch" href="/ai.txt">
  <link rel="prefetch" href="/llms.txt">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
  <meta name="theme-color" content="#8b4513">
  {% set meta_desc_fr = subtitle | default('Apprenez Git à travers une aventure heroic fantasy. Un cours gamifié et bilingue avec 23 quêtes, des cheatsheets et des exercices pratiques. 100% gratuit et open source.') %}
  {% set meta_desc_en = subtitle | default('Learn Git through an epic fantasy adventure. A gamified, bilingual course with 23 quests, cheatsheets and hands-on exercises. 100% free and open source.') %}
  {% set meta_desc = meta_desc_fr if lang == "fr" else meta_desc_en %}
  {% set meta_title = title + " - " + ("Les Chroniques du Versionneur" if lang == "fr" else "The Git Chronicles") %}
  {% set site_name = "Les Chroniques du Versionneur" if lang == "fr" else "The Git Chronicles" %}
  <meta name="description" content="{{ meta_desc }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{{ 'fr_FR' if lang == 'fr' else 'en_US' }}">
  <meta property="og:locale:alternate" content="{{ 'en_US' if lang == 'fr' else 'fr_FR' }}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:title" content="{{ meta_title }}">
  <meta property="og:description" content="{{ meta_desc }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ site_name }}">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ meta_title }}">
  <meta name="twitter:description" content="{{ meta_desc }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/og-image.png">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "{% if lang == 'fr' %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif %}",
    "description": "{% if lang == 'fr' %}Un cours Git interactif et gamifié avec un récit heroic fantasy. 23 quêtes, de git init au CI/CD. Bilingue FR/EN, gratuit et open source.{% else %}An interactive, gamified Git course with a fantasy narrative. 23 quests from git init to CI/CD. Bilingual FR/EN, free and open source.{% endif %}",
    "url": "{{ site.url }}/{{ lang }}/",
    "provider": {
      "@type": "Person",
      "name": "Dxsk",
      "url": "https://github.com/Dxsk"
    },
    "inLanguage": ["fr", "en"],
    "isAccessibleForFree": true,
    "license": "https://opensource.org/licenses/MIT",
    "teaches": ["Git", "Version Control", "CI/CD", "GitHub", "GitLab", "Git LFS", "Radicle"],
    "numberOfCredits": 23,
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "online",
      "courseWorkload": "23 quests + 6 bonus quests"
    }
  }
  </script>
</head>
<body>
  <div class="wip-banner">
    {% if lang == "fr" %}
      🚧 Ce site est en cours de construction. Le contenu peut évoluer.
    {% else %}
      🚧 This site is a work in progress. Content may change.
    {% endif %}
  </div>
  <header class="site-header">
    <a href="/{{ lang }}/" class="logo">
      {%- if lang == "fr" %}Les Chroniques du Versionneur{% else %}The Git Chronicles{% endif -%}
    </a>
    <div class="header-actions">
      <a href="https://github.com/Dxsk/git-chronicles" class="header-github" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <div class="lang-switch">
        {% if lang == "fr" %}
          <span class="lang-active">FR</span>
          {% if quest_id %}
            <a href="/en/quests/{{ quest_slug_en }}/" hreflang="en">EN</a>
          {% elif cheatsheet_slug_en %}
            <a href="/en/cheatsheets/{{ cheatsheet_slug_en }}/" hreflang="en">EN</a>
          {% else %}
            <a href="/en/" hreflang="en">EN</a>
          {% endif %}
        {% else %}
          {% if quest_id %}
            <a href="/fr/quetes/{{ quest_slug_fr }}/" hreflang="fr">FR</a>
          {% elif cheatsheet_slug_fr %}
            <a href="/fr/cheatsheets/{{ cheatsheet_slug_fr }}/" hreflang="fr">FR</a>
          {% else %}
            <a href="/fr/" hreflang="fr">FR</a>
          {% endif %}
          <span class="lang-active">EN</span>
        {% endif %}
      </div>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">&#9776;</button>
    </div>
  </header>

  <div class="page-wrapper">
    <aside class="sidebar-nav" id="nav-container"></aside>
    <main class="main-content" data-pagefind-body>
      {{ content | safe }}
      <nav class="nav-footer" id="nav-footer"></nav>
    </main>
  </div>

  <script>
    window.__lang = "{{ lang }}";
  </script>
  <script src="/assets/js/nav.js"></script>
  <script src="/assets/js/highlight.js"></script>

  <!-- Search FAB + modal -->
  <button class="search-fab" id="search-fab" aria-label="{% if lang == 'fr' %}Rechercher{% else %}Search{% endif %}">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  </button>
  <div class="search-overlay" id="search-overlay">
    <div class="search-modal" role="dialog" aria-modal="true" aria-label="{% if lang == 'fr' %}Recherche{% else %}Search{% endif %}">
      <div class="search-modal-header">
        <span class="search-modal-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          {% if lang == 'fr' %}Recherche{% else %}Search{% endif %}
          <kbd class="search-kbd">Ctrl+K</kbd>
        </span>
        <button class="search-close" id="search-close" aria-label="{% if lang == 'fr' %}Fermer{% else %}Close{% endif %}">&times;</button>
      </div>
      <div id="search-container"></div>
    </div>
  </div>

  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    (function() {
      var fab = document.getElementById("search-fab");
      var overlay = document.getElementById("search-overlay");
      var closeBtn = document.getElementById("search-close");
      var initialized = false;

      function openSearch() {
        if (!initialized) {
          if (typeof PagefindUI === "undefined") {
            document.getElementById("search-container").innerHTML = "<p style='padding:1rem;color:#8b4513;'>{% if lang == 'fr' %}Recherche indisponible en mode développement. Lancez <code>npm run build</code> pour générer l'index.{% else %}Search unavailable in dev mode. Run <code>npm run build</code> to generate the index.{% endif %}</p>";
            initialized = true;
            overlay.classList.add("active");
            return;
          }
          new PagefindUI({
            element: "#search-container",
            showSubResults: true,
            showImages: false,
            translations: window.__lang === "fr" ? {
              placeholder: "Rechercher dans les chroniques...",
              zero_results: "Aucun résultat pour \u00ab [SEARCH_TERM] \u00bb",
              many_results: "[COUNT] résultats pour \u00ab [SEARCH_TERM] \u00bb",
              one_result: "1 résultat pour \u00ab [SEARCH_TERM] \u00bb"
            } : {
              placeholder: "Search the chronicles..."
            }
          });
          initialized = true;
        }
        overlay.classList.add("active");
        document.body.style.overflow = "hidden";
        setTimeout(function() {
          var input = overlay.querySelector(".pagefind-ui__search-input");
          if (input) input.focus();
        }, 100);
      }

      function closeSearch() {
        overlay.classList.remove("active");
        document.body.style.overflow = "";
      }

      fab.addEventListener("click", openSearch);
      closeBtn.addEventListener("click", closeSearch);
      overlay.addEventListener("click", function(e) {
        if (e.target === overlay) closeSearch();
      });
      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") closeSearch();
        if ((e.ctrlKey || e.metaKey) && e.key === "k") { e.preventDefault(); openSearch(); }
      });
    })();
  </script>
</body>
</html>
