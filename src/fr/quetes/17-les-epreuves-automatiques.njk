    <!-- Récapitulatif YAML -->
    <h2>Récapitulatif YAML</h2>

    <table>
      <thead>
        <tr>
          <th>Élément</th>
          <th>Rôle</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>strategy: matrix:</code></td>
          <td>Définir les combinaisons OS/versions à tester</td>
        </tr>
        <tr>
          <td><code>needs: job_name</code></td>
          <td>Créer une dépendance entre les jobs</td>
