        <tr>
          <td>Développement</td>
          <td>Ton bureau privé</td>
          <td>Toi seul</td>
        </tr>
        <tr>
          <td>Staging</td>
          <td>Salle de répétition</td>
          <td>L'équipe</td>
        </tr>
        <tr>
          <td>Production</td>
          <td>La Grande Bibliothèque</td>
          <td>Tout le monde</td>
        </tr>
      </tbody>
    </table>

